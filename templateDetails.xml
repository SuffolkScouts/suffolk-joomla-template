<?xml version="1.0" encoding="utf-8"?>
<extension version="4.0" type="template" client="site" method="upgrade">
    <name>Suffolk Scouts</name>
    <version>2.0.0</version>
    <creationDate>April 2026</creationDate>
    <author>Suffolk Scouts</author>
    <authorEmail>webmaster@suffolkscouts.org.uk</authorEmail>
    <copyright>Copyright (C) 2026 Suffolk Scouts</copyright>
    <description>TPL_SUFFOLKDEV_XML_DESCRIPTION</description>
    <files>
        <filename>component.php</filename>
        <filename>error.php</filename>
        <filename>favicon.ico</filename>
        <filename>index.php</filename>
        <filename>templateDetails.xml</filename>
        <filename>template_preview.png</filename>
        <filename>template_thumbnail.png</filename>
        <folder>css</folder>
        <folder>fonts</folder>
        <folder>html</folder>
        <folder>images</folder>
        <folder>js</folder>
        <folder>language</folder>
    </files>
    <positions>
        <position>banner</position>
        <position>breadcrumbs</position>
        <position>sidebar-left</position>
        <position>sidebar-right</position>
        <position>above-content</position>
        <position>below-content</position>
        <position>footer</position>
        <position>debug</position>
    </positions>
    <languages folder="language">
        <language tag="en-GB">en-GB/en-GB.tpl_suffolkdev.ini</language>
        <language tag="en-GB">en-GB/en-GB.tpl_suffolkdev.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="advanced">
                <field name="favicon" type="text" default=""
                    label="TPL_SUFFOLKDEV_FAVICON"
                    description="TPL_SUFFOLKDEV_FAVICON_DESC"
                    filter="string" />
                <field name="customcss" type="text" default=""
                    label="TPL_SUFFOLKDEV_CUSTOMCSS"
                    description="TPL_SUFFOLKDEV_CUSTOMCSS_DESC"
                    filter="string" />
            </fieldset>
        </fields>
    </config>
</extension>
